# PostgreSQL connection string (cloud)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/advuman

# Local offline fallback (SQLite + async driver)
# DATABASE_URL=sqlite+aiosqlite:///./advuman_local.db

# Anthropic API key (for LLM-assisted event classification)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override default EWMA lambda per index
# EWMA_LAMBDA_RPI=0.048
# EWMA_LAMBDA_LSI=0.048
# EWMA_LAMBDA_CPI=0.048

# Optional: CUSUM parameters
# CUSUM_K=0.5
# CUSUM_H=4.5

# Optional: Dynamic source config from Google Sheets (collector enable/disable, URL overrides)
# SOURCES_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/<ID>/export?format=csv&gid=0

# Optional: OSINT event log Google Sheet (analyst-submitted pre-classified events)
# Override the hardcoded defaults if you use a different sheet or add new lanes.
# OSINT_SHEET_ID=1QmssLXafz3g3nOJ6YJpfHCd53LmD4MVgaiarbxGlmtM
# OSINT_SHEET_GIDS={"UK-India": 834780247, "UK-Egypt": 843292959}
